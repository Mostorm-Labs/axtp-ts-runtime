{
  "name": "@axtp/runtime",
  "version": "0.9.0",
  "description": "TypeScript runtime / SDK for AXTP, with optional Node.js and Browser adapters.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:conformance": "vitest run --config devtools/conformance/vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "axtp": {
    "specRepository": "https://github.com/Mostorm-Labs/axtp",
    "specTag": "spec/v0.9.0",
    "specVersion": "0.9.0"
  },
  "packageManager": "pnpm@11.3.0"
}
