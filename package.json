{
  "name": "@axtp/runtime",
  "version": "0.11.0",
  "description": "TypeScript runtime / SDK for AXTP, with optional Node.js and Browser adapters.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:conformance": "vitest run tests/conformance/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "axtp": {
    "specRepository": "https://github.com/Mostorm-Labs/axtp",
    "specTag": "spec/v0.11.0",
    "specVersion": "0.11.0"
  },
  "packageManager": "pnpm@11.3.0"
}
